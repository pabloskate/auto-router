 customer support.\"]}]]}],[\"$\",\"div\",null,{\"className\":\"feature-cell\",\"children\":[[\"$\",\"div\",null,{\"className\":\"feature-icon-row\",\"children\":[[\"$\",\"div\",null,{\"className\":\"feature-dot cyan\"}],[\"$\",\"h3\",null,{\"children\":\"Automatic Failover\"}]]}],[\"$\",\"p\",null,{\"children\":\"If a provider is down or slow, we automatically try the next best model. Your users never see a 500.\"}]]}],[\"$\",\"div\",null,{\"className\":\"feature-cell\",\"children\":[[\"$\",\"div\",null,{\"className\":\"feature-icon-row\",\"children\":[[\"$\",\"div\",null,{\"className\":\"feature-dot indigo\"}],[\"$\",\"h3\",null,{\"children\":\"See Every Decision\"}]]}],[\"$\",\"p\",null,{\"children\":\"Query any request ID to see exactly why a model was chosen, what the confidence was, and what the fallback chain looked like.\"}]]}]]}]]}]\na:[\"$\",\"section\",null,{\"className\":\"landing-section\",\"children\":[[\"$\",\"div\",null,{\"className\":\"section-label\",\"children\":\"Configuration\"}],[\"$\",\"h2\",null,{\"className\":\"section-heading\",\"children\":\"Change models without changing code.\"}],[\"$\",\"p\",null,{\"className\":\"section-desc\",\"children\":[\"Add a new model, update your rules, or create a new profile—all from the dashboard. Your code never changes. It just keeps sending \",[\"$\",\"code\",null,{\"className\":\"code\",\"children\":\"model: \\\"auto\\\"\"}],\".\"]}],[\"$\",\"div\",null,{\"className\":\"compare\",\"children\":[[\"$\",\"div\",null,{\"className\":\"compare-pane\",\"children\":[[\"$\",\"div\",null,{\"className\":\"compare-header before\",\"children\":\"Without Auto Router\"}],[\"$\",\"div\",null,{\"className\":\"compare-body plain\",\"children\":[[\"$\",\"div\",null,{\"className\":\"compare-item\",\"children\":[[\"$\",\"span\",null,{\"className\":\"compare-x\",\"children\":\"✘\"}],[\"$\",\"span\",null,{\"children\":\"Write if-statements for every model decision\"}]]}],[\"$\",\"div\",null,{\"className\":\"compare-item\",\"ch