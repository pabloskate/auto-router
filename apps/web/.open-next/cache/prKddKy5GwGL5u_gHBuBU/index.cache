\":\"One router, many strategies.\"}],[\"$\",\"p\",null,{\"className\":\"section-desc\",\"children\":\"Create named profiles that act as virtual model names. Each profile can override the model catalog, routing instructions, and defaults — so different parts of your app get different routing behavior from the same endpoint.\"}],[\"$\",\"div\",null,{\"className\":\"profiles-row\",\"children\":[[\"$\",\"div\",null,{\"className\":\"profile-preview\",\"children\":[[\"$\",\"div\",null,{\"className\":\"profile-preview-id\",\"children\":\"auto-cheap\"}],[\"$\",\"p\",null,{\"className\":\"profile-preview-desc\",\"children\":\"Restrict the catalog to low-cost models. Great for internal tools, batch jobs, and simple chat.\"}],[\"$\",\"span\",null,{\"className\":\"profile-tag cyan\",\"children\":\"filtered catalog\"}],[\"$\",\"span\",null,{\"className\":\"profile-tag indigo\",\"children\":\"cost-first rules\"}]]}],[\"$\",\"div\",null,{\"className\":\"profile-preview\",\"children\":[[\"$\",\"div\",null,{\"className\":\"profile-preview-id\",\"children\":\"auto-coding\"}],[\"$\",\"p\",null,{\"className\":\"profile-preview-desc\",\"children\":\"Only high-thinking models. Custom instructions that prefer Claude for code and o3 for algorithms.\"}],[\"$\",\"span\",null,{\"className\":\"profile-tag cyan\",\"children\":\"thinking models only\"}],[\"$\",\"span\",null,{\"className\":\"profile-tag indigo\",\"children\":\"code-first rules\"}]]}],[\"$\",\"div\",null,{\"className\":\"profile-preview\",\"children\":[[\"$\",\"div\",null,{\"className\":\"profile-preview-id\",\"children\":\"auto-support\"}],[\"$\",\"p\",null,{\"className\":\"profile-preview-desc\",\"children\":\"Customer-facing tier. Fast models with guardrails. Blocklist anything experimental.\"}],[\"$\",\"span\",null,{\"className\":\"profile-tag cyan\",\"children\":\"fast defaults\"}],[\"$\",\"span\",null,{\"className\":\"profile-tag indigo\",\"children\":\"strict blocklist\"}]]}]]}]]}]\nc:[\"$\",\"section\",null,{\"className\"