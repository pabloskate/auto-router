{
  "name": "auto-router",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run --workspaces build",
    "dev": "npm run dev -w @auto-router/web",
    "test": "npm run --workspaces --if-present test",
    "typecheck": "npm run --workspaces typecheck",
    "eval:router:dry": "node scripts/router-eval.mjs --mode router --dry-run",
    "eval:model:dry": "node scripts/router-eval.mjs --mode model --dry-run",
    "eval:router": "node scripts/router-eval.mjs --mode router",
    "eval:model": "node scripts/router-eval.mjs --mode model"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
