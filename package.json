{
  "name": "auto-router",
  "version": "0.1.0",
  "description": "Self-hostable, OpenAI-compatible LLM routing proxy with BYOK, explainability, and Cloudflare deployment support.",
  "license": "AGPL-3.0-only",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run --workspaces build",
    "dev": "npm run dev -w @auto-router/web",
    "dev:seed": "npm run db:seed && npm run dev -w @auto-router/web",
    "verify:admin": "node scripts/verify-admin-flow.mjs",
    "db:seed": "npx wrangler d1 execute auto-router-test --local --file=infra/d1/schema.sql --config apps/web/wrangler.toml",
    "test": "npm run --workspaces --if-present test",
    "typecheck": "npm run --workspaces typecheck",
    "eval:router:dry": "node scripts/router-eval.mjs --mode router --dry-run",
    "eval:model:dry": "node scripts/router-eval.mjs --mode model --dry-run",
    "eval:router": "node scripts/router-eval.mjs --mode router",
    "eval:model": "node scripts/router-eval.mjs --mode model"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "playwright": "^1.58.2",
    "wrangler": "^3.92.0"
  }
}
