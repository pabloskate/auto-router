{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "allowJs": false,
    "strict": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@custom-router/core": ["packages/core/src/index.ts"],
      "@custom-router/core/*": ["packages/core/src/*"],
      "@custom-router/data": ["packages/data/src/index.ts"],
      "@custom-router/data/*": ["packages/data/src/*"]
    }
  }
}
